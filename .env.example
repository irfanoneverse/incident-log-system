# ──────────────────────────────────────────────
# IT Incident Log System — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/incident_log"

# ── Authentication ────────────────────────────
# Single-user credentials for the IT operator
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_me_in_production"

# ── Session ────────────────────────────────────
# Random secret for signing session cookies (min 32 chars)
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace_with_a_random_secret_at_least_32_chars_long"

# ── App (optional) ────────────────────────────
# NODE_ENV is set automatically by Nuxt (development | production)
# NODE_ENV="development"
